# ==========================================
# 1. 致命安全与环境变量 (Security & Env)
# ==========================================
.env
.env.*
!.env.example
*.pem
*.key
# [架构师补充] 屏蔽可能导出的数据库备份文件
*.sql
*.dump

# ==========================================
# 2. 向量数据库与业务数据 (Databases & Data)
# ==========================================
/backend/vector_db/
vector_db/
*.db
*.sqlite3
*.sqlite
/backend/uploads/
# [架构师补充] RAG 文档处理与微信多媒体下载的临时碎件区
/backend/temp/
/backend/tmp/
/backend/media/

# ==========================================
# 3. Python 后端核心屏蔽 (Backend / Python)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env_python/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
htmlcov/
.pytest_cache/
# [架构师补充] 现代 Python 类型检查与 Linter 缓存
.mypy_cache/
.ruff_cache/
# [架构师补充] 异步任务队列 Celery 留下的调度碎片 (未来可能用到)
celerybeat-schedule
*.pid

# ==========================================
# 4. 前端与 Node.js 核心屏蔽 (Frontend / Vue)
# ==========================================
node_modules/
dist/
dist-ssr/
build/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# [架构师补充] Vue/Vite 编译与语法检查缓存
.eslintcache
.stylelintcache
node_modules/.cache/

# ==========================================
# 5. 操作系统与 IDE 缓存 (OS & IDE)
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
# [架构师补充] 苹果系统顽固隐藏文件
.AppleDouble
.LSOverride

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (PyCharm / WebStorm)
.idea/
*.iws
*.iml
*.ipr

# ==========================================
# 6. 系统日志 (Logs)
# ==========================================
*.log
logs/
/backend/logs/