# ==========================================
# 1. 应用基本配置
# ==========================================
SECRET_KEY=yoursecretkeyhere-keep-it-long-and-secure
DEBUG=True
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600

# ==========================================
# 2. 数据库与缓存 (本地调试适配)
# ==========================================
# 🚨 物理对齐：本地调试必须使用 127.0.0.1
DATABASE_URL=mysql+pymysql://admin:password@127.0.0.1:3306/poclain_ai_db
REDIS_URL=redis://127.0.0.1:6379/0

# ==========================================
# 3. 微信配置 (需填入你的真实参数)
# ==========================================
WX_APPID=填写你的
WX_APPSECRET=填写你的
WX_TOKEN=填写你的
WX_ENCODING_AES_KEY=填写你的

# ==========================================
# 4. AI 算力引擎
# ==========================================
DASHSCOPE_API_KEY=填写你的
ANONYMIZED_TELEMETRY=False
POSTHOG_DISABLED=1
CHROMA_TELEMETRY_IMPL=none

# ==========================================
# 5. 安全防线与连接池
# ==========================================
CORS_ORIGINS=["*"]
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=10

# 系统初始管理员密码
ADMIN_PASSWORD=PoclainAdmin2026!